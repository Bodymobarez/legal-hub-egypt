{
  "name": "workspace",
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.2",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) [ \"${CI:-}\" = \"true\" ] && exit 0; echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "dev": "bash scripts/dev-stack.sh",
    "dev:no-docker": "bash scripts/dev-no-docker.sh",
    "build:cloudflare": "bash scripts/cloudflare-build.sh",
    "deploy:cloudflare": "bash scripts/cloudflare-deploy.sh",
    "dev:cloudflare": "pnpm exec wrangler dev",
    "dev:egypt": "PORT=${PORT:-5173} BASE_PATH=${BASE_PATH:-/} API_PROXY_TARGET=${API_PROXY_TARGET:-http://127.0.0.1:8080} pnpm --filter @workspace/egypt-advocates dev",
    "build": "pnpm run typecheck && pnpm --filter @workspace/egypt-advocates build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "esbuild": "0.27.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "wrangler": "4.93.0"
  },
  "dependencies": {}
}
