# Copy to `.env` in this directory and fill in. `.env` is gitignored.

# Neon (or any Postgres). Use single quotes if the URL contains `?` or `&`.
# DATABASE_URL='postgresql://USER:PASSWORD@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require'

# Optional; a random long string in production — MUST match on Cloudflare Worker secrets.
# SESSION_SECRET=

# Cloudflare local worker dev: copy `.dev.vars.example` → `.dev.vars` and set the same values.

# When running `pnpm --filter @workspace/scripts seed` locally or against Neon,
# omit to use EgyptAdvocates@2026, or override the super-admin password seed:
# ADMIN_PASSWORD=

# Super-admin email after seed: admin@egypt-advocates.com
